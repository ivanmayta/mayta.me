---
import Section from "../Section.astro"
import HTML from "@/icons/html.astro"
import CSS from "@/icons/css.astro"
import JavaScript from "@/icons/javascript.astro"
import TypeScript from "@/icons/type.astro"
import React from "@/icons/react.astro"
import Node from "@/icons/node.astro"
import MySQL from "@/icons/sql.astro"
import Git from "@/icons/git.astro"
import GitHub from "@/icons/GitHub.astro"
import Tailwind from "@/icons/tailwind.astro"
import Next from "@/icons/next.astro"
import Swift from "@/icons/swift.astro"
import SwiftUI from "@/icons/swiftui.astro"
import Kotlin from "@/icons/kotlin.astro"
import Flutter from "@/icons/flutter.astro"
import Android from "@/icons/android.astro"
import Django from "@/icons/django.astro"
import Python from "@/icons/python.astro"
import Bootstrap from "@/icons/bootstrap.astro"
import Strapi from "@/icons/strapi.astro"
import Postgresql from "@/icons/postgresql.astro"
import DigitalOcean from "@/icons/digitalOcean.astro"
import AstroIcon from "@/icons/astroIcon.astro"
import Supabase from "@/icons/supabase.astro"
import Figma from "@/icons/figma.astro"
import Canva from "@/icons/canva.astro"
import Capcut from "@/icons/capcut.astro"
import Wordpress from "@/icons/wordpress.astro"
import BootstrapStudio from "@/icons/bootstrapstudio.astro"
import Claude from "@/icons/claude.astro"
import type { Skills } from "@/cv"

const { skills } = Astro.props as { skills: Skills[] }

const SKILLS_ICONS: Record<string, any> = {
    Next,
    HTML,
    CSS,
    JavaScript,
    TypeScript,
    React,
    Node,
    MySQL,
    Git,
    GitHub,
    Tailwind,
    Swift,
    SwiftUI,
    Kotlin,
    Flutter,
    Android,
    Django,
    Python,
    Bootstrap,
    Strapi,
    Postgresql,
    DigitalOcean,
    Astro: AstroIcon,
    Supabase,
    Figma,
    Canva,
    Capcut,
    Wordpress,
    BootstrapStudio,
    Claude,
}

const categories = [
    {
        label: "Main stack",
        type: "main",
        groups: [
            ["Astro", "Next.js", "React", "TypeScript", "Node", "Tailwind", "HTML","CSS"],
        ],
    },
    {
        label: "exposure",
        type: "familiar",
        groups: [
            [
                "Python",
                "FastAPI",
                "Postgresql",
                "MySQL",
                "Kotlin",
                "Android Studio",
                "React Native ",
                "Strapi",
                "Wordpress",
                "Supabase",
                "n8n"
               
            ],
        ],
    },
    {
        label: "tooling",
        type: "tools",
        groups: [
            [
                "Claude Code",
                "Git",
                "GitHub",
                "Figma",
                "Canva",
                "DigitalOcean",
                "Supabase",
            ],
        ],
    },
]
---

<Section title="Habilidades">
    <div class="skills-grid">
        {
            categories.map(({ label, type, groups }) => (
                <div class="category-row">
                    <span class="category-label">{label}</span>
                    <div class="groups">
                        {groups.map((group) => (
                            <ul class="badge-list">
                                {group.map((name) => {
                                    const iconName =
                                        name === "Next.js"
                                            ? "Next"
                                            : name === "Claude Code"
                                              ? "Claude"
                                              : name
                                    const Icon = SKILLS_ICONS[iconName]
                                    return (
                                        <li class={`badge badge--${type}`}>
                                            {Icon && <Icon />}
                                            <span>{name}</span>
                                        </li>
                                    )
                                })}
                            </ul>
                        ))}
                    </div>
                </div>
            ))
        }
    </div>
</Section>

<style>
    .skills-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .category-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

    .category-label {
        font-family: monospace;
        font-size: 0.7rem;
        color: #999;
        text-transform: lowercase;
        letter-spacing: 0.03em;
        min-width: 64px;
        padding-top: 3px;
        flex-shrink: 0;
    }

    .groups {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .badge-list {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border-radius: 6px;
        font-size: 0.78rem;
        font-weight: 500;
        padding: 0 0.4rem;
        height: 22px;
        line-height: 1;
        box-sizing: border-box;
    }

    .badge :global(svg) {
        width: 12px;
        height: 12px;
        flex-shrink: 0;
        display: block;
    }

    .badge--main {
        background: #eee;
        color: #111;
    }

    .badge--familiar {
        background: transparent;
        border: 1px solid #ddd;
        color: #333;
    }

    .badge--tools {
        background: transparent;
        border: 1px solid #ddd;
        color: #333;
    }

    @media print {
        .badge {
            font-size: 10px;
        }
        .category-label {
            font-size: 9px;
        }
    }
</style>
