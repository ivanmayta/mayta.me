---
import GitHub from "@/icons/GitHub.astro"
import Section from "../Section.astro"
import type { Projects } from "@/cv"
const { projects, title } = Astro.props as {
    projects: Projects[]
    title: string
}

---

<Section title={title ? title : "Proyectos"}>
    <ul class="project-list">
        {
            projects.slice(0, 4).map(({ url, highlights, name, isActive, github, link, technologies, related }) => (
                <li class="project-row">
                    <div class="project-left">
                        <a class="project-name" href={url} target="_blank" title={`Ver ${name}`}>
                            {name}
                        </a>
                        {isActive && <span class="dot">•</span>}
                        <ul class="tag-list">
                            {technologies?.map((t) => <li class="tag">{t}</li>)}
                        </ul>
                        {github && (
                            <a class="github-link ml-auto" href={github} target="_blank" title={`Código de ${name}`}>
                                <GitHub />
                            </a>
                        )}
                        {link && (
                            <a class="github-link ml-auto" href={link} target="_blank" title={`Ver ${name}`}>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                            </a>
                        )}
                    </div>
                    <p class="project-desc">{highlights.join(" · ")}</p>
                    {related?.map((r) => (
                        <div class="related-row">
                            <span class="related-arrow">↳</span>
                            <a class="related-name" href={r.url} target="_blank">{r.name}</a>
                            {r.github && (
                                <a class="github-link" href={r.github} target="_blank" title={`Código de ${r.name}`}>
                                    <GitHub />
                                </a>
                            )}
                        </div>
                    ))}
                </li>
            ))
        }
    </ul>
    <a class="ver-mas" href="https://iverse.dev/projects" target="_blank">Ver más</a>
</Section>

<style>
    .project-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .project-row {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .project-left {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 4px;
    }

    .project-name {
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        color: inherit;
        white-space: nowrap;
    }

    .project-name:hover {
        text-decoration: underline;
    }

    .dot {
        color: #22c55e;
        font-size: 1rem;
        line-height: 1;
        animation: pulse 2s infinite;
    }

    .project-desc {
        font-family: monospace;
        font-size: 0.875rem;
        color: #555;
        margin: 0;
        line-height: 1.4;
    }

.tag-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 3px;
    }

    .tag {
        font-size: 0.7rem;
        font-weight: 500;
        background: #eee;
        border-radius: 4px;
        padding: 1px 5px;
        color: #333;
        white-space: nowrap;
    }

    .github-link {
        color: #666;
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-left: auto;
    }

    .github-link:hover {
        color: #000;
    }

    .related-row {
        display: flex;
        align-items: center;
        gap: 5px;
        padding-left: 4px;
    }

    .related-arrow {
        font-size: 0.75rem;
        color: #111;
        font-weight: 700;
    }

    .related-name {
        font-size: 0.8rem;
        font-weight: 600;
        color: #555;
        text-decoration: none;
    }

    .related-name:hover {
        text-decoration: underline;
    }

    .ver-mas {
        display: block;
        text-align: right;
        font-size: 0.8rem;
        margin-top: 8px;
        color: inherit;
    }

    .ver-mas:hover {
        text-decoration: underline;
    }


    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }

    @media print {
        .project-name { font-size: 10px; }
        .project-desc { font-size: 9px; }
        .tag { font-size: 8px; }
    }
</style>
