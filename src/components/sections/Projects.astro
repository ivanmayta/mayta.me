---
import GitHub from "@/icons/GitHub.astro"
import Section from "../Section.astro"
import type { Projects } from "@/cv"
const { projects, title } = Astro.props as {
    projects: Projects[]
    title: string
}
---

<Section title={title ? title : "Proyectos"}>
    <ul class="project-list">
        {
            projects.slice(0, 4).map(({ url, highlights, name, isActive, github, technologies }) => (
                <li class="project-row">
                    <div class="project-left">
                        <a class="project-name" href={url} target="_blank" title={`Ver ${name}`}>
                            {name}
                        </a>
                        {isActive && <span class="dot">•</span>}
                        <ul class="tag-list">
                            {technologies?.map((t) => <li class="tag">{t}</li>)}
                        </ul>
                        {github && (
                            <a class="github-link ml-auto" href={github} target="_blank" title={`Código de ${name}`}>
                                <GitHub />
                            </a>
                        )}
                    </div>
                    <p class="project-desc">{highlights.join(" · ")}</p>
                </li>
            ))
        }
    </ul>
    <a class="ver-mas" href="https://iverse.dev/projects" target="_blank">Ver más</a>
</Section>

<style>
    .project-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .project-row {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .project-left {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 4px;
    }

    .project-name {
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        color: inherit;
        white-space: nowrap;
    }

    .project-name:hover {
        text-decoration: underline;
    }

    .dot {
        color: #22c55e;
        font-size: 1rem;
        line-height: 1;
        animation: pulse 2s infinite;
    }

    .project-desc {
        font-family: monospace;
        font-size: 0.875rem;
        color: #555;
        margin: 0;
        line-height: 1.4;
    }

.tag-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 3px;
    }

    .tag {
        font-size: 0.7rem;
        font-weight: 500;
        background: #eee;
        border-radius: 4px;
        padding: 1px 5px;
        color: #333;
        white-space: nowrap;
    }

    .github-link {
        color: #666;
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-left: auto;
    }

    .github-link:hover {
        color: #000;
    }

    .ver-mas {
        display: block;
        text-align: right;
        font-size: 0.8rem;
        margin-top: 8px;
        color: inherit;
    }

    .ver-mas:hover {
        text-decoration: underline;
    }


    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }

    @media print {
        .project-name { font-size: 10px; }
        .project-desc { font-size: 9px; }
        .tag { font-size: 8px; }
    }
</style>
